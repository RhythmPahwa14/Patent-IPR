{
  "name": "Express Auth + Patent Filing API Contract",
  "version": "1.0.0",
  "baseUrl": "https://express-backend-ajedhzd3h0bfbse5.westindia-01.azurewebsites.net",
  "auth": {
    "type": "Bearer",
    "header": "Authorization",
    "format": "Bearer <token>"
  },
  "endpoints": [
    {
      "group": "Auth",
      "method": "POST",
      "path": "/api/auth/register",
      "authRequired": false,
      "description": "Register a user (client or agent)"
    },
    {
      "group": "Auth",
      "method": "POST",
      "path": "/api/auth/login",
      "authRequired": false,
      "description": "Login user and receive JWT"
    },
    {
      "group": "Auth",
      "method": "GET",
      "path": "/api/auth/me",
      "authRequired": true,
      "description": "Get current logged-in user"
    },
    {
      "group": "Auth",
      "method": "GET",
      "path": "/api/auth/admin-only",
      "authRequired": true,
      "description": "Admin only protected route example"
    },
    {
      "group": "Patent Filings",
      "method": "POST",
      "path": "/api/patent-filings",
      "authRequired": true,
      "description": "Create patent filing draft or submit directly"
    },
    {
      "group": "Patent Filings",
      "method": "POST",
      "path": "/api/patent-filings/{id}/submit",
      "authRequired": true,
      "description": "Submit a DRAFT patent filing"
    },
    {
      "group": "Patent Filings",
      "method": "PATCH",
      "path": "/api/patent-filings/{id}",
      "authRequired": true,
      "description": "Update draft filing fields"
    },
    {
      "group": "Patent Filings",
      "method": "GET",
      "path": "/api/patent-filings/{referenceNumber}",
      "authRequired": true,
      "description": "Get filing detail by reference number"
    },
    {
      "group": "Patent Filings",
      "method": "POST",
      "path": "/api/patent-filings/{id}/documents",
      "authRequired": true,
      "description": "Attach supporting document URL to filing"
    },
    {
      "group": "Patent Filings",
      "method": "GET",
      "path": "/api/client/patents",
      "authRequired": true,
      "description": "List patent filings with pagination and optional status filter"
    },
    {
      "group": "Patent Filings (Legacy)",
      "method": "POST",
      "path": "/api/v1/patents/submit",
      "authRequired": true,
      "description": "Legacy patent submit endpoint for frontend compatibility"
    },
    {
      "group": "Patent Filings (Legacy)",
      "method": "GET",
      "path": "/api/v1/patents/user/filings",
      "authRequired": true,
      "description": "Legacy list endpoint for frontend compatibility"
    },
    {
      "group": "Patent Filings (Legacy)",
      "method": "GET",
      "path": "/api/v1/patents/{referenceNumber}",
      "authRequired": true,
      "description": "Legacy detail endpoint for frontend compatibility"
    },
    {
      "group": "Files",
      "method": "POST",
      "path": "/api/files/presign",
      "authRequired": true,
      "description": "Generate a pre-signed upload URL (mock implementation)"
    }
  ]
}
